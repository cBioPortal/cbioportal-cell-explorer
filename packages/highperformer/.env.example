# Deployment
# Base URL path for deployment (e.g. /cbioportal-cell-explorer/ for GitHub Pages)
VITE_BASE_URL=/

# Feature flags
# Enable deck.gl stats widget (default: false)
VITE_ENABLE_STATS_WIDGET=false

# Enable query profiler bar and /profile route (default: false)
VITE_ENABLE_PROFILER=false

# Enable experimental Zarr structure inspector (default: false)
VITE_ENABLE_ZARR_VIEW=false

# PostMessage (iframe embedding)
# Enable postMessage event listener for receiving config from a parent iframe (default: false)
VITE_ENABLE_POSTMESSAGE=false

# Comma-separated origin patterns for postMessage filtering (required when enabled)
# Examples: https://*.cbioportal.org, https://localhost:3000, * (any origin, dev only)
# VITE_POSTMESSAGE_ORIGIN=*
